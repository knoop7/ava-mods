      "type": "text",
      "key": "rate",
      "label": "Speech Rate",
      "description": "Rate adjustment, e.g. +0%, +10%, -5%.",
      "defaultValue": "+0%"
    },
    {
      "type": "text",
      "key": "volume",
      "label": "Volume",
      "description": "Volume adjustment, e.g. +0%, -10%.",
      "defaultValue": "+0%"
    },
    {
      "type": "text",
      "key": "pitch",
      "label": "Pitch",
      "description": "Pitch adjustment, e.g. +0Hz, +2Hz.",
      "defaultValue": "+0Hz"
    },
    {
      "type": "number",
      "key": "tcp_port",
      "label": "TCP Port",
      "description": "TCP port for Home Assistant Wyoming clients.",
      "dialogHint": "Default 10301. Home Assistant Wyoming TTS integration connects here.",
      "defaultValue": "10301",
      "min": 1024,
      "max": 65535,
      "step": 1
    },
    {
      "type": "text",
      "key": "listen_address",
      "label": "Listen Address",
      "description": "Bind address for the Wyoming server.",
      "dialogHint": "0.0.0.0 allows LAN clients (typical). Use 127.0.0.1 for local-only.",
      "defaultValue": "0.0.0.0"
    },
    {
      "type": "switch",
      "key": "auto_start",
      "label": "Auto Start",
      "description": "Start the TTS server when this mod is enabled.",
      "defaultValue": "true"
    },
    {
      "type": "switch",
      "key": "mdns_enabled",
      "label": "mDNS Discovery",
      "description": "Broadcast _wyoming._tcp for Home Assistant auto-discovery.",
      "defaultValue": "true"
    },
    {
      "type": "switch",
      "key": "show_last_text",
      "label": "Show Last TTS Text",
      "description": "Expose last synthesized text as a Home Assistant text sensor.",
      "defaultValue": "false"
    },
    {
      "type": "switch",
      "key": "show_diagnostic_entities",
      "label": "Show Diagnostic Entities",
      "description": "Expose server status and restart button in Home Assistant.",
      "defaultValue": "false"
