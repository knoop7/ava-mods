+static char *_plist_dup_string(plist_t dict, const char *key) {
+    plist_t node = plist_dict_get_item(dict, key);
+    char *val = NULL;
+    if (node) {
+        plist_get_string_val(node, &val);
+    }
+    if (!val) {
+        return NULL;
+    }
+    char *copy = strdup(val);
+    plist_mem_free(val);
+    return copy;
+}
