{
  "id": "tuya-s8e-support",
  "name": "Tuya S8E",
  "version": "1.0.10",
  "author": "Ava",
  "description": "Device support for Tuya S8E with screen backlight, small display control, and climate readings",
  "icon": "mdi:tablet-dashboard",
  "libs": [
    "libs/tuya-s8e-support.jar"
  ],
  "manager": "com.ava.mods.tuyas8e.TuyaS8EManager",
  "jar_hash": "07a9deb9686f9067954ca68f5b094567",
  "entities": [
    {
      "type": "switch",
      "id": "screen_backlight",
      "name": "Screen Backlight",
      "icon": "mdi:monitor",
      "on": "setScreenBacklight:true",
      "off": "setScreenBacklight:false",
      "read": "isScreenBacklightOn",
      "refresh_interval_ms": 30000
    },
    {
      "type": "switch",
      "id": "small_screen_backlight",
      "name": "Small Screen Backlight",
      "icon": "mdi:monitor-small",
      "on": "setSmallScreenBacklight:true",
      "off": "setSmallScreenBacklight:false",
      "read": "isSmallScreenBacklightOn",
      "refresh_interval_ms": 30000
    },
    {
      "type": "sensor",
      "id": "temperature",
      "name": "Temperature",
      "icon": "mdi:thermometer",
      "unit": "°C",
      "class": "temperature",
      "read": "getTemperature",
      "refresh_interval_ms": 30000
    },
    {
      "type": "sensor",
      "id": "humidity",
      "name": "Humidity",
      "icon": "mdi:water-percent",
      "unit": "%",
      "class": "humidity",
      "read": "getHumidity",
      "refresh_interval_ms": 30000
    },
    {
      "type": "text_sensor",
      "id": "rotary_position",
      "name": "Rotary Position",
      "icon": "mdi:rotate-3d-variant",
      "read": "getRotaryPositionText",
      "refresh_interval_ms": 500
    },
    {
      "type": "button",
      "id": "reset_rotary_position",
      "name": "Reset Rotary Position",
      "icon": "mdi:restart",
      "category": "diagnostic",
      "press": "resetRotaryPosition"
    },
    {
      "type": "text_sensor",
      "id": "gesture_direction",
      "name": "Gesture Direction",
      "icon": "mdi:gesture-swipe",
      "read": "getGestureDirection",
      "refresh_interval_ms": 500
    }
  ]
}
