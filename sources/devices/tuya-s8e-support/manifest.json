{
  "id": "tuya-s8e-support",
  "name": "Tuya S8E",
  "version": "1.0.2",
  "author": "Ava",
  "description": "Device support for Tuya S8E with screen backlight, small display control, and climate readings",
  "icon": "mdi:tablet-dashboard",
  "libs": [
    "libs/tuya-s8e-support.jar"
  ],
  "manager": "com.ava.mods.tuyas8e.TuyaS8EManager",
  "jar_hash": "872d8df0a3e809e8164b081beef5e82c",
  "entities": [
    {
      "type": "switch",
      "id": "screen_backlight",
      "name": "Screen Backlight",
      "icon": "mdi:monitor",
      "on": "setScreenBacklight:true",
      "off": "setScreenBacklight:false",
      "read": "isScreenBacklightOn"
    },
    {
      "type": "switch",
      "id": "small_screen_backlight",
      "name": "Small Screen Backlight",
      "icon": "mdi:monitor-small",
      "on": "setSmallScreenBacklight:true",
      "off": "setSmallScreenBacklight:false",
      "read": "isSmallScreenBacklightOn"
    },
    {
      "type": "sensor",
      "id": "temperature",
      "name": "Temperature",
      "icon": "mdi:thermometer",
      "unit": "°C",
      "class": "temperature",
      "read": "getTemperature"
    },
    {
      "type": "sensor",
      "id": "humidity",
      "name": "Humidity",
      "icon": "mdi:water-percent",
      "unit": "%",
      "class": "humidity",
      "read": "getHumidity"
    }
  ]
}
