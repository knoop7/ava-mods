{
  "id": "ha-edge-tts",
  "name": "HA Edge TTS",
  "version": "1.0.7",
  "author": "Ava",
  "description": "Edge TTS for Home Assistant via Wyoming protocol.",
  "detail_description": "Cloud-based TTS using Microsoft Edge TTS voices. Wyoming TCP server for Home Assistant voice pipelines. 400+ voices in 40+ languages.",
  "icon": "mdi:microsoft-edge",
  "libs": [
    "libs/ha-edge-tts-manager.jar"
  ],
  "manager": "com.ava.mods.edgetts.EdgeTtsManager",
  "permissions": [
    "android.permission.INTERNET",
    "android.permission.ACCESS_NETWORK_STATE"
  ],
  "entities": [
    {
      "type": "binary_sensor",
      "id": "server_running",
      "name": "TTS Server",
      "icon": "mdi:server-network",
      "class": "connectivity",
      "category": "diagnostic",
      "enabledByConfig": "show_diagnostic_entities",
      "read": "isServerRunning"
    },
    {
      "type": "button",
      "id": "restart_server",
      "name": "Restart TTS Server",
      "icon": "mdi:restart",
      "enabledByConfig": "show_diagnostic_entities",
      "press": "restartServer"
    },
    {
      "type": "text_sensor",
      "id": "last_text",
      "name": "Last TTS Text",
      "icon": "mdi:text",
      "enabledByConfig": "show_last_text",
      "read": "getLastText"
    }
  ],
