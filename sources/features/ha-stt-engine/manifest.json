{
  "id": "ha-stt-engine",
  "name": "HA STT Engine",
  "version": "1.0.9",
  "author": "Ava",
  "description": "Local Wyoming STT for Home Assistant (multilingual offline).",
  "detail_description": "First run downloads a ~230MB SenseVoice model (zh/en/ja/ko/Cantonese). Wyoming TCP on port 10300 for Home Assistant voice pipelines.",
  "icon": "mdi:microphone-message",
  "libs": [
    "libs/ha-stt-engine-manager.jar",
    "libs/sherpa-onnx.jar",
    "libs/jni/arm64-v8a/libonnxruntime.so",
    "libs/jni/arm64-v8a/libsherpa-onnx-c-api.so",
    "libs/jni/arm64-v8a/libsherpa-onnx-cxx-api.so",
    "libs/jni/arm64-v8a/libsherpa-onnx-jni.so",
    "libs/jni/armeabi-v7a/libonnxruntime.so",
    "libs/jni/armeabi-v7a/libsherpa-onnx-c-api.so",
    "libs/jni/armeabi-v7a/libsherpa-onnx-cxx-api.so",
    "libs/jni/armeabi-v7a/libsherpa-onnx-jni.so"
  ],
  "manager": "com.ava.mods.hasttengine.HaSttEngineManager",
  "permissions": [
    "android.permission.INTERNET",
    "android.permission.ACCESS_NETWORK_STATE"
  ],
  "status_panel": [
    {
      "type": "download_strip",
      "label": "Model",
      "read": "getDownloadProgress",
      "listener_id": "download_progress",
      "status_read": "getModelStatusDisplay",
      "status_listener_id": "model_status",
      "description": "SenseVoice ~230MB · zh/en/ja/ko/Cantonese · background download",
      "detail_description": "Downloads model_q8.onnx and tokens.txt on first run. Wyoming TCP port 10300 is available after the model is ready and loaded.",
      "ready_keywords": ["ready", "Ready", "已就绪"],
      "downloading_keywords": ["downloading", "Downloading", "下载中"],
      "error_keywords": ["error", "Error", "failed", "Failed", "错误", "失败"],
      "inline_config_keys": ["recognition_language"],
      "actions": [
        {
          "label": "Download model",
          "press": "downloadModel",
          "style": "primary"
        },
        {
          "label": "Delete model",
          "press": "deleteModel",
          "style": "destructive"
        }
      ]
    }
  ],
  "entities": [
    {
      "type": "binary_sensor",
      "id": "server_running",
      "name": "STT Server",
      "icon": "mdi:server-network",
      "class": "connectivity",
      "category": "diagnostic",
      "enabledByConfig": "show_diagnostic_entities",
      "read": "isServerRunning"
    },
    {
      "type": "text_sensor",
      "id": "model_status",
      "name": "Model Status",
      "icon": "mdi:database",
      "category": "diagnostic",
      "enabledByConfig": "show_diagnostic_entities",
      "read": "getModelStatus"
    },
    {
      "type": "sensor",
      "id": "download_progress",
      "name": "Download Progress",
      "icon": "mdi:download",
      "unit": "%",
      "category": "diagnostic",
      "enabledByConfig": "show_diagnostic_entities",
      "accuracy_decimals": 0,
      "refresh_interval_ms": 1000,
      "read": "getDownloadProgress"
    },
    {
      "type": "text_sensor",
      "id": "last_transcript",
      "name": "Last Transcript",
      "icon": "mdi:text",
      "category": "diagnostic",
      "enabledByConfig": "show_diagnostic_entities",
      "read": "getLastTranscript"
    },
    {
      "type": "text_sensor",
      "id": "last_emotion",
      "name": "STT Emotion",
      "icon": "mdi:emoticon-outline",
      "enabledByConfig": "show_emotion_sensor",
      "read": "getLastEmotion"
    },
    {
      "type": "text_sensor",
      "id": "last_audio_event",
      "name": "STT Audio Event",
      "icon": "mdi:speaker-wireless",
      "enabledByConfig": "show_audio_event_sensor",
      "read": "getLastAudioEvent"
    },
    {
      "type": "button",
      "id": "download_model",
      "name": "Download Model",
      "icon": "mdi:download",
      "enabledByConfig": "show_diagnostic_entities",
      "press": "downloadModel"
    },
    {
      "type": "button",
      "id": "restart_server",
      "name": "Restart STT Server",
      "icon": "mdi:restart",
      "enabledByConfig": "show_diagnostic_entities",
      "press": "restartServer"
    },
    {
      "type": "button",
      "id": "delete_model",
      "name": "Delete Model",
      "icon": "mdi:delete",
      "enabledByConfig": "show_diagnostic_entities",
      "press": "deleteModel"
    }
  ],
  "config": [
    {
      "type": "select",
      "key": "recognition_language",
      "label": "Recognition Language",
      "description": "Fixed decode language for SenseVoice (zh and en are separate).",
      "dialogHint": "en = English (default). zh = Mandarin only. auto = detect among zh/en/ja/ko/yue. ja/ko/yue lock to Japanese/Korean/Cantonese.",
      "defaultValue": "en",
      "options": ["en", "zh", "auto", "ja", "ko", "yue"]
    },
    {
      "type": "number",
      "key": "tcp_port",
      "label": "TCP Port",
      "description": "TCP port for Home Assistant Wyoming clients.",
      "dialogHint": "Default 10300. Home Assistant Wyoming integration connects here after the model is ready.",
      "defaultValue": "10300",
      "min": 1024,
      "max": 65535,
      "step": 1
    },
    {
      "type": "text",
      "key": "listen_address",
      "label": "Listen Address",
      "description": "Bind address for the Wyoming server.",
      "dialogHint": "0.0.0.0 allows LAN clients (typical). Use 127.0.0.1 for local-only testing.",
      "defaultValue": "0.0.0.0"
    },
    {
      "type": "switch",
      "key": "auto_start",
      "label": "Auto Start",
      "description": "Start the STT server when this mod is enabled.",
      "defaultValue": "true"
    },
    {
      "type": "switch",
      "key": "mdns_enabled",
      "label": "mDNS Discovery",
      "description": "Broadcast _wyoming._tcp for Home Assistant auto-discovery.",
      "defaultValue": "true"
    },
    {
      "type": "number",
      "key": "num_threads",
      "label": "Inference Threads",
      "description": "CPU threads for SenseVoice inference.",
      "dialogHint": "2 is a good default on speakers and tablets. Raise only if recognition is slow and CPU headroom is available.",
      "defaultValue": "2",
      "min": 1,
      "max": 8,
      "step": 1
    },
    {
      "type": "switch",
      "key": "show_emotion_sensor",
      "label": "Show Emotion Sensor",
      "description": "Expose STT Emotion as a separate Home Assistant text sensor.",
      "defaultValue": "true"
    },
    {
      "type": "switch",
      "key": "show_audio_event_sensor",
      "label": "Show Audio Event Sensor",
      "description": "Expose STT Audio Event as a separate Home Assistant text sensor.",
      "defaultValue": "true"
    },
    {
      "type": "switch",
      "key": "show_diagnostic_entities",
      "label": "Show Diagnostic Entities",
      "description": "Expose server, model status, download progress, and control buttons in Home Assistant.",
      "dialogHint": "Off by default. Emotion and audio event sensors have their own toggles above.",
      "defaultValue": "false"
    },
    {
      "type": "switch",
      "key": "auto_download",
      "label": "Auto Download Model",
      "description": "Download the SenseVoice model on first start.",
      "dialogHint": "About 230MB to external app storage (Android/data/.../files/ha-stt-engine/). Disable if you prefer manual download from the buttons above.",
      "defaultValue": "true"
    }
  ],
  "jar_hash": "6a9f0a6c50e41c743988faeff7147904"
}

