{
  "id": "zigbee-gateway-mod",
  "name": "Zigbee Gateway",
  "version": "1.1.2",
  "author": "Ava",
  "description": "Serial to TCP bridge for Zigbee coordinators. Supports Tuya S6E/T6E/S7E/S9E, NSPanel Pro.",
  "icon": "mdi:zigbee",
  "libs": [
    "libs/zigbee-gateway-manager.jar"
  ],
  "manager": "com.ava.mods.zigbee.ZigbeeGatewayManager",
  "entities": [
    {
      "type": "binary_sensor",
      "id": "server_running",
      "name": "Zigbee Status",
      "icon": "mdi:server-network",
      "class": "connectivity",
      "category": "diagnostic",
      "read": "isServerRunning"
    },
    {
      "type": "button",
      "id": "restart_server",
      "name": "Zigbee Restart",
      "icon": "mdi:restart",
      "category": "diagnostic",
      "press": "restartServer"
    }
  ],
  "config": [
    {
      "type": "text",
      "key": "serial_port",
      "label": "Serial Port Path",
      "description": "Device path of the Zigbee coordinator serial port",
      "dialogHint": "e.g. /dev/ttyS5, /dev/ttyUSB0, /dev/ttyACM0, /dev/ttyAMA0",
      "defaultValue": "/dev/ttyS5"
    },
    {
      "type": "select",
      "key": "baudrate",
      "label": "Baudrate",
      "description": "Serial communication speed",
      "dialogHint": "Most Zigbee coordinators use 115200 bps",
      "defaultValue": "115200",
      "options": [
        "9600",
        "19200",
        "38400",
        "57600",
        "115200",
        "230400",
        "460800",
        "921600"
      ]
    },
    {
      "type": "number",
      "key": "tcp_port",
      "label": "TCP Port",
      "description": "Network port for TCP socket server",
      "dialogHint": "Clients connect to this port to access the serial data",
      "defaultValue": "8888",
      "min": 1024,
      "max": 65535,
      "step": 1
    },
    {
      "type": "text",
      "key": "listen_address",
      "label": "Listen Address",
      "description": "IP address to bind the TCP server",
      "dialogHint": "Use 0.0.0.0 to allow all connections, or 127.0.0.1 for local only",
      "defaultValue": "0.0.0.0"
    },
    {
      "type": "switch",
      "key": "auto_start",
      "label": "Auto Start",
      "description": "Automatically start the server when mod is enabled",
      "defaultValue": "true"
    },
    {
      "type": "switch",
      "key": "rtscts_flow",
      "label": "RTS/CTS Flow Control",
      "description": "Enable hardware flow control",
      "defaultValue": "false"
    }
  ]
}
